rules_version = '2';

// Firebase Storage Security Rules for VITE App APK Distribution
service firebase.storage {
  match /b/{bucket}/o {
    
    // Public read access for APK releases
    // Anyone with the download URL can read/download APKs
    match /apk-releases/{apkFile} {
      allow read: if true;
      allow write: if request.auth != null; // Only authenticated users can upload
    }
    
    // Default: Deny all other access
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
